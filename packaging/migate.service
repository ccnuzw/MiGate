[Unit]
Description=MiGate Service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
# MiGate still runs as root because this service manages systemd units, writes
# root-owned core configs, and binds/administers system resources during install
# and repair flows.
User=root
WorkingDirectory=/var/lib/migate
ExecStart=/usr/local/bin/migate serve --host 0.0.0.0 --config /etc/migate/panel.json
Restart=on-failure
RestartSec=5s
LimitNOFILE=1048576
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ReadWritePaths=/etc/migate /var/lib/migate /var/log/migate /run/migate /usr/local/bin /usr/local/share/xray /etc/systemd/system
CapabilityBoundingSet=CAP_NET_BIND_SERVICE
RestrictAddressFamilies=AF_INET AF_INET6 AF_UNIX
StandardOutput=journal
StandardError=journal
LogRateLimitIntervalSec=30s
LogRateLimitBurst=200

[Install]
WantedBy=multi-user.target
